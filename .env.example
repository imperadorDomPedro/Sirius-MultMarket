# Banco de dados
DB_URL=jdbc:postgresql://host:5432/guiadegurupi
DB_USERNAME=gurupi
DB_PASSWORD=senha_segura_aqui

# JWT — gerar com: openssl rand -base64 64
# Deve ser o mesmo valor usado pela API admin (tokens compartilhados)
JWT_SECRET=troque_por_valor_seguro_gerado

# MinIO / S3-compatible
MINIO_ENDPOINT=https://seu-endpoint-s3
MINIO_ACCESS_KEY=sua_access_key
MINIO_SECRET_KEY=sua_secret_key

# CORS — URL real do frontend público em produção
CORS_ALLOWED_ORIGINS=https://seudominio.com

# Spring profile
SPRING_PROFILES_ACTIVE=prod
